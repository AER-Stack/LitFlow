# ===============================
# LitFlow Backend Environment
# ===============================

# PostgreSQL Database URL
# Format: postgres://username:password@hostname:port/dbname
DATABASE_URL=

# JWT Secret Key
# Use a long random string (64+ chars) for security
JWT_SECRET=

# Affiliate Tags (for external book links)
VITE_BOOKSHOP_AFFILIATE_ID=litflow-20
VITE_AMAZON_AFFILIATE_TAG=litflow-20

# Server Port
PORT=3000

# Optional: Node Environment (development or production)
NODE_ENV=development
